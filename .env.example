# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session encryption (generate with: openssl rand -hex 32)
NUXT_SESSION_PASSWORD=

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Comma-separated emails allowed to login
ALLOWED_EMAILS=

# GitHub fine-grained PAT (repo scope for bug reporter)
GITHUB_TOKEN=

# Platform API keys (for cost collection)
ANTHROPIC_ADMIN_API_KEY=
RAILWAY_API_TOKEN=
RENDER_API_KEY=
RESEND_API_KEY=
NEON_API_KEY=
TURSO_API_TOKEN=
UPTIMEROBOT_API_KEY=

# Alert notifications (Resend email + CallMeBot WhatsApp)
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
WHATSAPP_PHONE=
WHATSAPP_APIKEY=

# Google Analytics (optional)
NUXT_PUBLIC_GA_ID=
